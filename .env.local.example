# Supabase — copy this file to .env.local and fill in your project values.
# Find these in: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only — never prefix with NEXT_PUBLIC_. Used after JWT verification for
# preference/rating/profile writes (bypasses RLS). Find it in:
# Supabase Dashboard → Project Settings → API → service_role (secret)
# Also set this in Netlify → Site configuration → Environment variables.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Must match your running app (used in email confirmation / OAuth / password-reset redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase Dashboard → Authentication → URL Configuration → Redirect URLs
# must include (at least):
#   http://localhost:3000/auth/callback
# Password reset emails use:
#   {NEXT_PUBLIC_SITE_URL}/auth/callback?next=/reset-password
# Add your production origin equivalents when deploying.

# Optional — Google Books API key for higher rate limits
# GOOGLE_BOOKS_API_KEY=your-google-books-api-key

# Optional — New York Times Books API (bestsellers strip on Browse; search works without it)
# Free key: https://developer.nytimes.com/ → Get Started → Books API
# Also set this in Netlify → Site configuration → Environment variables for production.
# NYT_BOOKS_API_KEY=

# Optional — ISBNdb (https://isbndb.com/isbn-database)
# Also set in Netlify → Site configuration → Environment variables for production.
# ISBNDB_API_KEY=

# Optional — Hardcover.app GraphQL (server-only; do NOT use NEXT_PUBLIC_)
# Exact name: HARDCOVER_API_TOKEN (no spaces). Value = raw JWT from
# https://hardcover.app/account/api (or Account → API) — not "Bearer …".
# Also set in Netlify → Site configuration → Environment variables for
# Production (and Preview if needed), then trigger a new deploy.
# Restart `npm run dev` after changing this locally.
# HARDCOVER_API_TOKEN=
