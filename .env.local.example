# Supabase — copy this file to .env.local and fill in your project values.
# Find these in: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Must match your running app (used in email confirmation / OAuth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional — Google Books API key for higher rate limits
# GOOGLE_BOOKS_API_KEY=your-google-books-api-key

# Optional — New York Times Books API (bestsellers on Browse)
# Get a key at https://developer.nytimes.com/
# NYT_BOOKS_API_KEY=your-nyt-books-api-key
